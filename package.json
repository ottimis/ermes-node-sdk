{
  "name": "@ottimis/ermes-node-sdk",
  "version": "2.0.0",
  "description": "Node/TypeScript SDK for the Ermes notification platform — port of ermes-php-sdk",
  "keywords": [
    "ermes",
    "notification",
    "sdk",
    "ottimis",
    "jwt",
    "jwks",
    "socket.io"
  ],
  "license": "ISC",
  "author": "Ottimis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ottimis/ermes-node-sdk.git"
  },
  "homepage": "https://github.com/ottimis/ermes-node-sdk#readme",
  "bugs": {
    "url": "https://github.com/ottimis/ermes-node-sdk/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "jest",
